rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated (including anonymously)
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. User Profiles & Sub-collections
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;

      match /ghl_accounts/{accountId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /ghl_contacts/{contactId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // 2. Conversations
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated();
    }

    // 3. Messages
    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    // 4. SMS Logs
    match /sms_logs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only written by PHP backend
    }

    // 5. Integrations
    match /integrations/{integrationId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only written by PHP backend
    }

    // 6. Agency Users
    match /agency_users/{userId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only written by PHP backend
    }

    // 7. GHL Tokens
    match /ghl_tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only written by PHP backend
    }

    // 8. Agency Wallet
    match /agency_wallet/{walletId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only written by PHP backend
    }
  }
}
