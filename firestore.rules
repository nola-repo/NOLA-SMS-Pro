rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function tokenLocationIds() {
      return request.auth.token.location_ids is list
        ? request.auth.token.location_ids
        : (
          request.auth.token.location_id is string
            ? [request.auth.token.location_id]
            : []
        );
    }

    function canAccessLocation(locationId) {
      return isAuthenticated()
        && locationId is string
        && locationId in tokenLocationIds();
    }

    function incomingLocationId() {
      return request.resource.data.location_id;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId
        || canAccessLocation(resource.data.location_id)
        || canAccessLocation(resource.data.active_location_id)
      );
      allow write: if isAuthenticated() && request.auth.uid == userId;

      match /ghl_accounts/{accountId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /ghl_contacts/{contactId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /conversations/{conversationId} {
      allow read: if canAccessLocation(resource.data.location_id);
      allow create: if canAccessLocation(incomingLocationId());
      allow update: if canAccessLocation(resource.data.location_id)
        && incomingLocationId() == resource.data.location_id;
      allow delete: if canAccessLocation(resource.data.location_id);
    }

    match /messages/{messageId} {
      allow read: if canAccessLocation(resource.data.location_id);
      allow create: if canAccessLocation(incomingLocationId());
      allow update: if canAccessLocation(resource.data.location_id)
        && incomingLocationId() == resource.data.location_id;
      allow delete: if false;
    }

    match /sms_logs/{logId} {
      allow read: if canAccessLocation(resource.data.location_id);
      allow write: if false;
    }

    match /integrations/{integrationId} {
      allow read: if canAccessLocation(resource.data.location_id)
        || canAccessLocation(resource.data.locationId);
      allow write: if false;
    }

    match /agency_users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId
        || (
          request.auth.token.company_id is string
          && (
            request.auth.token.company_id == resource.data.company_id
            || request.auth.token.company_id == resource.data.agency_id
          )
        )
      );
      allow write: if false;
    }

    match /ghl_tokens/{tokenId} {
      allow read: if canAccessLocation(resource.data.location_id)
        || canAccessLocation(resource.data.locationId)
        || (
          request.auth.token.company_id is string
          && (
            request.auth.token.company_id == tokenId
            || request.auth.token.company_id == resource.data.companyId
            || request.auth.token.company_id == resource.data.company_id
          )
        );
      allow write: if false;
    }

    match /agency_wallet/{walletId} {
      allow read: if isAuthenticated()
        && request.auth.token.company_id is string
        && request.auth.token.company_id == walletId;
      allow write: if false;
    }
  }
}