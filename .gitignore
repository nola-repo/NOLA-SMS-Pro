# Ignore logs and runtime files (SMS)
logs/
*.log

# Keep the api/logs/ directory itself (for daily rotating log files)
# but ignore the actual log files inside it
!api/logs/
api/logs/*.log
api/webhook/sms_log.txt
api/webhook/last_payload.json

# Ignore debug/scratch log dumps and test scripts
raw_logs.txt
raw_logs_utf8.txt
scratch/

# SSL cert bundle (local curl use only, never commit)
cacert.pem

# Planning/design docs (local reference only)
docs/

# Ignore VSCode config
.vscode/

# Ignore sensitive files
.env
config.local.php
api/webhook/nola-sms-pro-*.json

# Frontend Dependencies and Builds
**/node_modules/
**/dist/
**/.nuxt/
**/.output/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Local clone for patching upstream frontend (not part of this repo)
_nola-sms-pro-frontend/

# Backups and Temporary Files
vendor/
frontend_old/
temp_*/
.DS_Store
Thumbs.db