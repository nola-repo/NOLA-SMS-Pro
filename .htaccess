# NOLA SMS Pro — Apache Rewrite Rules
# Maps production URLs to actual PHP files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    Options -MultiViews

    # ── CORS: Handle OPTIONS preflight at Apache level ───────────────
    # Browsers send OPTIONS before POST with custom headers.
    # Apache must respond 204 before PHP even runs.
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=204,L]

    # If the request is for an existing file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── OAuth ────────────────────────────────────────────────────────────
    # /oauth/callback -> /ghl_callback.php
    RewriteRule ^oauth/callback$ /ghl_callback.php [L,QSA]

    # ── Webhook endpoints (public URLs without /api/ prefix) ─────────
    # /webhook/send_sms     -> /api/webhook/send_sms.php
    # /webhook/receive_sms  -> /api/webhook/receive_sms.php
    # /webhook/retrieve_status -> /api/webhook/retrieve_status.php
    # /webhook/debug_ghl    -> /api/webhook/debug_ghl.php
    # Generic: /webhook/XXX -> /api/webhook/XXX.php
    RewriteRule ^webhook/(.+)$ /api/webhook/$1.php [L,QSA]

    # ── Specialized Frontend-Backend Reconciliation ──────────────────
    # /api/bulk-campaigns -> /api/webhook/fetch_bulk_messages.php
    RewriteRule ^api/bulk-campaigns$ /api/webhook/fetch_bulk_messages.php [L,QSA]

    # /api/ghl-contacts -> /api/ghl_contacts.php (Standardized on the more robust version)
    RewriteRule ^api/ghl-contacts$ /api/ghl_contacts.php [L,QSA]

    # ── Generic API endpoints ───────────────────────────────────────────
    # /api/messages -> /api/messages.php (if the .php file exists)
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L,QSA]

</IfModule>

# ── CORS headers for ALL responses ──────────────────────────────────
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE, PATCH"
    Header always set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Webhook-Secret, X-GHL-Location-ID, X-GHL-LocationID"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

# Ensure PHP files are executed
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>
