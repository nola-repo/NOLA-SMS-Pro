RewriteEngine On
Options +FollowSymLinks

# ── CORS preflight: Apache handles OPTIONS directly so headers are always present ──
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
    Header always set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Webhook-Secret"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=204,L]

# Hide .php by redirecting direct access to clean URLs
# (Only triggers for real browser/client requests; internal rewrites are not redirected.)
RewriteCond %{THE_REQUEST} \s/+api/webhook/send_sms\.php[\s?] [NC]
RewriteRule ^api/webhook/send_sms\.php$ /webhook/send_sms [R=301,L]
RewriteCond %{THE_REQUEST} \s/+api/webhook/receive_sms\.php[\s?] [NC]
RewriteRule ^api/webhook/receive_sms\.php$ /webhook/receive_sms [R=301,L]
RewriteCond %{THE_REQUEST} \s/+api/webhook/retrieve_status\.php[\s?] [NC]
RewriteRule ^api/webhook/retrieve_status\.php$ /webhook/retrieve_status [R=301,L]
RewriteCond %{THE_REQUEST} \s/+api/messages\.php[\s?] [NC]
RewriteRule ^api/messages\.php$ /api/messages [R=301,L]
RewriteCond %{THE_REQUEST} \s/+api/contacts\.php[\s?] [NC]
RewriteRule ^api/contacts\.php$ /api/contacts [R=301,L]
RewriteCond %{THE_REQUEST} \s/+api/credits\.php[\s?] [NC]
RewriteRule ^api/credits\.php$ /api/credits [R=301,L]
RewriteCond %{THE_REQUEST} \s/+api/get_credit_transactions\.php[\s?] [NC]
RewriteRule ^api/get_credit_transactions\.php$ /api/get_credit_transactions [R=301,L]
RewriteCond %{THE_REQUEST} \s/+ghl_callback\.php[\s?] [NC]
RewriteRule ^ghl_callback\.php$ /oauth/callback [R=301,L]

RewriteRule ^webhook/send_sms$ /api/webhook/send_sms.php [L]
RewriteRule ^webhook/send_sms\.php$ /api/webhook/send_sms.php [L]
RewriteRule ^webhook/receive_sms$ /api/webhook/receive_sms.php [L]
RewriteRule ^webhook/retrieve_status$ /api/webhook/retrieve_status.php [L]

# Message history API (for Web UI)
RewriteRule ^api/messages$ /api/messages.php [L]

# Contacts API (for Web UI)
RewriteRule ^api/contacts$ /api/contacts.php [L]

# Credit balance API (for Web UI)
RewriteRule ^api/credits$ /api/credits.php [L]

# Credit transactions ledger API
RewriteRule ^api/get_credit_transactions$ /api/get_credit_transactions.php [L]

# Bulk campaigns API (for Web UI)
RewriteRule ^api/bulk-campaigns$ /api/webhook/fetch_bulk_messages.php [L]

# GHL Contacts proxy (for Web UI — proxies to GoHighLevel API)
RewriteRule ^api/ghl-contacts$ /api/ghl_contacts.php [L]

# Conversations API (for Web UI sidebar)
RewriteRule ^api/conversations$ /api/conversations.php [L]

# OAuth callback (GHL / marketplace integrations)
RewriteRule ^oauth/callback$ /ghl_callback.php [L]





