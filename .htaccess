# NOLA SMS Pro — Apache Rewrite Rules
# Maps production URLs to actual PHP files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── Preserve Authorization header through rewrites ──────────────────
    # Apache strips HTTP_AUTHORIZATION when a RewriteRule is processed.
    # This rule re-exposes it so all PHP endpoints can read it via $_SERVER.
    # NOTE: No [L] flag here — we must NOT stop rewrite processing after this
    # rule, otherwise ALL routing rules below would be skipped and every
    # request would return a 404 from Apache.
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    Options -MultiViews

    # ── CORS: OPTIONS preflight ────────────────────────────────────────
    # OPTIONS requests fall through to the PHP file matched by the rewrite
    # rules below. Every PHP endpoint includes cors.php which returns 204
    # with proper CORS headers. The mod_headers block at the bottom of
    # this file is a safety net that ensures CORS headers are always present.


    # If the request is for an existing file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── v2 hot-path bypasses (avoid Laravel bridge process spawn) ────────
    RewriteRule ^api/v2/ghl-contacts/?$ /api/ghl_contacts.php [NC,L,QSA]
    RewriteRule ^api/v2/ghl-conversations/?$ /api/ghl-conversations.php [NC,L,QSA]

    # ── Laravel v2 (same container) ──────────────────────────────────────
    # Route remaining /api/v2/* traffic to Laravel shim; keep legacy endpoints intact.
    RewriteRule ^api/v2/?$ /api/v2/index.php [NC,L,QSA]
    RewriteRule ^api/v2/(.*)$ /api/v2/index.php [NC,L,QSA]

    # ── OAuth ────────────────────────────────────────────────────────────
    # /oauth/callback         -> /ghl_callback.php          (subaccount app)
    # /oauth/agency-callback  -> /ghl_agency_callback.php   (agency app)
    RewriteRule ^oauth/callback/?$        /ghl_callback.php        [NC,L,QSA]
    RewriteRule ^oauth/agency-callback/?$ /ghl_agency_callback.php [NC,L,QSA]

    # ── Hide .php extension: redirect direct .php access to clean URLs ──
    # This prevents users from accessing the .php files directly if they know the path.
    RewriteCond %{THE_REQUEST} \s/+api/webhook/send_sms\.php[\s?] [NC]
    RewriteRule ^api/webhook/send_sms\.php$ /webhook/send_sms [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+api/webhook/receive_sms\.php[\s?] [NC]
    RewriteRule ^api/webhook/receive_sms\.php$ /webhook/receive_sms [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+api/webhook/retrieve_status\.php[\s?] [NC]
    RewriteRule ^api/webhook/retrieve_status\.php$ /webhook/retrieve_status [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+api/messages\.php[\s?] [NC]
    RewriteRule ^api/messages\.php$ /api/messages [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+api/contacts\.php[\s?] [NC]
    RewriteRule ^api/contacts\.php$ /api/contacts [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+api/credits\.php[\s?] [NC]
    RewriteRule ^api/credits\.php$ /api/credits [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+api/get_credit_transactions\.php[\s?] [NC]
    RewriteRule ^api/get_credit_transactions\.php$ /api/get_credit_transactions [R=301,L]
    RewriteCond %{THE_REQUEST} \s/+ghl_callback\.php[\s?] [NC]
    RewriteRule ^ghl_callback\.php$ /oauth/callback [R=301,L]

    # ── Webhook endpoints (public URLs without /api/ prefix) ─────────
    # /webhook/send_sms     -> /api/webhook/send_sms.php
    # /webhook/receive_sms  -> /api/webhook/receive_sms.php
    # /webhook/retrieve_status -> /api/webhook/retrieve_status.php
    # /webhook/debug_ghl    -> /api/webhook/debug_ghl.php
    # Generic: /webhook/XXX -> /api/webhook/XXX.php
    RewriteRule ^webhooks/ghl/conversation-message/?$ /api/webhook/ghl_conversation_message.php [NC,L,QSA]
    RewriteRule ^webhook/ghl/conversation-message/?$ /api/webhook/ghl_conversation_message.php [NC,L,QSA]
    RewriteRule ^webhook/([^/]+)\.php/?$ /api/webhook/$1.php [NC,L,QSA]
    RewriteRule ^webhook/(.+)/?$ /api/webhook/$1.php [NC,L,QSA]

    # ── SMS sending (frontend uses /api/sms) ─────────────────────────
    RewriteRule ^api/sms/?$ /api/webhook/send_sms.php [NC,L,QSA]
    RewriteRule ^api/send_sms(\.php)?/?$ /api/webhook/send_sms.php [NC,L,QSA]

    # ── Specialized Frontend-Backend Reconciliation ──────────────────
    # /api/bulk-campaigns -> /api/webhook/fetch_bulk_messages.php
    RewriteRule ^api/bulk-campaigns/?$ /api/webhook/fetch_bulk_messages.php [NC,L,QSA]

    # /api/ghl-contacts -> /api/ghl_contacts.php (Using the more robust underscore version)
    RewriteRule ^api/ghl-contacts/?$ /api/ghl_contacts.php [NC,L,QSA]

    # /api/ghl-conversations -> /api/ghl-conversations.php
    RewriteRule ^api/ghl-conversations/?$ /api/ghl-conversations.php [NC,L,QSA]

    # ── Public / Auth endpoints ────────────────────────────────────────────
    RewriteRule ^register/?$ install-register.php [NC,L,QSA]
    RewriteRule ^login/?$    install-login.php    [NC,L,QSA]
    RewriteRule ^forgot-password/?$ install-forgot-password.php [NC,L,QSA]

    RewriteRule ^api/auth/forgot-password-otp/?$ /api/auth/forgot_password_otp.php [NC,L,QSA]
    RewriteRule ^api/auth/reset-password-otp/?$  /api/auth/reset_password_otp.php  [NC,L,QSA]
    
    RewriteRule ^api/public/whitelabel/?$ /api/public/whitelabel.php [NC,L,QSA]
    RewriteRule ^api/auth/register-from-install/?$ /api/auth/register_from_install.php [NC,L,QSA]
    RewriteRule ^api/auth/resolve-install-selection/?$ /api/auth/resolve_install_selection.php [NC,L,QSA]
    RewriteRule ^api/auth/verify-install-token/?$  /api/auth/verify_install_token.php  [NC,L,QSA]
    RewriteRule ^api/auth/register/?$ /api/auth/register.php [NC,L,QSA]
    RewriteRule ^api/auth/login/?$    /api/auth/login.php    [NC,L,QSA]
    RewriteRule ^api/auth/me/?$       /api/auth/me.php       [NC,L,QSA]
    RewriteRule ^api/agency/ghl_autologin/?$ /api/agency/ghl_autologin.php [NC,L,QSA]
    # Legacy user-app path: location-level autologin.
    RewriteRule ^api/auth/ghl_autologin/?$ /api/auth/ghl_autologin.php [NC,L,QSA]
    RewriteRule ^api/agency/ghl_sso_decrypt/?$ /api/agency/ghl_sso_decrypt.php [NC,L,QSA]
    RewriteRule ^api/agency/link_company/?$ /api/agency/link_company.php [NC,L,QSA]
    RewriteRule ^api/agency/get_subaccounts/?$ /api/agency/get_subaccounts.php [NC,L,QSA]
    RewriteRule ^api/agency/update_subaccount/?$ /api/agency/update_subaccount.php [NC,L,QSA]
    RewriteRule ^api/agency/check_installs/?$ /api/agency/check_installs.php [NC,L,QSA]
    RewriteRule ^api/agency/install/provision/?$ /api/agency/install_provision.php [NC,L,QSA]
    RewriteRule ^api/agency/install/status/?$ /api/agency/install_status.php [NC,L,QSA]
    RewriteRule ^api/agency/locations/?$ /api/agency/locations.php [NC,L,QSA]

    # ── Billing endpoints ──────────────────────────────────────────────
    RewriteRule ^api/billing/agency_wallet/?$      /api/billing/agency_wallet.php      [NC,L,QSA]
    RewriteRule ^api/billing/subaccount_wallet/?$  /api/billing/subaccount_wallet.php  [NC,L,QSA]
    RewriteRule ^api/billing/subscription/?$       /api/billing/subscription.php       [NC,L,QSA]
    RewriteRule ^api/billing/plan-webhook/?$       /api/billing/plan_webhook.php       [NC,L,QSA]
    RewriteRule ^api/billing/transactions/?$       /api/billing/transactions.php       [NC,L,QSA]
    RewriteRule ^api/billing/credit_requests/?$    /api/billing/credit_requests.php    [NC,L,QSA]
    RewriteRule ^api/billing/auto_recharge_cron/?$ /api/billing/auto_recharge_cron.php [NC,L,QSA]

    # ── Generic API endpoints ───────────────────────────────────────────
    # /api/messages -> /api/messages.php
    # /api/contacts -> /api/contacts.php
    # /api/credits  -> /api/credits.php
    # /api/account  -> /api/account.php
    # etc.
    RewriteRule ^api/messages/?$ /api/messages.php [NC,L,QSA]
    RewriteRule ^api/contacts/?$ /api/contacts.php [NC,L,QSA]
    RewriteRule ^api/account/?$ /api/account.php [NC,L,QSA]
    RewriteRule ^api/account-sender/?$ /api/account-sender.php [NC,L,QSA]
    RewriteRule ^api/sender-requests/?$ /api/sender-requests.php [NC,L,QSA]
    RewriteRule ^api/notifications/?$ /api/notifications.php [NC,L,QSA]
    RewriteRule ^api/credits/?$ /api/credits.php [NC,L,QSA]
    RewriteRule ^api/get_credit_transactions/?$ /api/get_credit_transactions.php [NC,L,QSA]
    RewriteRule ^api/conversations/?$ /api/conversations.php [NC,L,QSA]
    RewriteRule ^api/templates/?$ /api/templates.php [NC,L,QSA]
    RewriteRule ^api/notification-settings/?$ /api/notification-settings.php [NC,L,QSA]
    RewriteRule ^api/check_message_status/?$ /api/check_message_status.php [NC,L,QSA]
    RewriteRule ^api/check-message-status/?$ /api/check_message_status.php [NC,L,QSA]

    # Catch-all: /api/XXX -> /api/XXX.php (if the .php file exists)
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)/?$ $1.php [NC,L,QSA]

</IfModule>

# ── CORS headers ─────────────────────────────────────────────────────
# CORS headers are handled dynamically by api/cors.php (PHP layer).
# We avoid setting them here (in mod_headers) to prevent duplicate
# Access-Control-Allow-Origin headers, which browsers reject.
# Preflight (OPTIONS) requests are allowed to fall through to PHP.


# Ensure PHP files are executed
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>
